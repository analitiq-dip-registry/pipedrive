{
  "connector_id": "12e25261-b29b-4471-aecb-48ebaa785f44",
  "connector_name": "Pipedrive",
  "connector_type": "api",
  "connector_descr": "Sales CRM and pipeline management platform",
  "connector_group_id": "58a3cd60-f9ac-4ea6-803e-611a2b00eb0b",
  "slug": "pipedrive",
  "base_url": "https://${api_domain}.pipedrive.com/api/v1/",
  "client_required": true,
  "auth": {
    "type": "oauth2_authorization_code",
    "authorize": {
      "url": "https://oauth.pipedrive.com/oauth/authorize?client_id=${client_id}&redirect_uri=${redirect_uri}&state=${state}"
    },
    "token_exchange": {
      "url": "https://oauth.pipedrive.com/oauth/token",
      "method": "POST",
      "content_type": "application/x-www-form-urlencoded",
      "headers": {
        "Authorization": "Basic ${basic_auth}"
      },
      "body": "grant_type=authorization_code&code=${code}&redirect_uri=${redirect_uri}"
    },
    "refresh": {
      "url": "https://oauth.pipedrive.com/oauth/token",
      "method": "POST",
      "content_type": "application/x-www-form-urlencoded",
      "headers": {
        "Authorization": "Basic ${basic_auth}"
      },
      "body": "grant_type=refresh_token&refresh_token=${refresh_token}"
    },
    "token_expiry_seconds": 3600
  },
  "headers": {
    "Accept": "application/json",
    "Content-Type": "application/json",
    "Authorization": "Bearer ${access_token}"
  },
  "form_fields": [
    {
      "name": "oauth2",
      "label": "Connect to Pipedrive",
      "type": "oauth2",
      "required": true
    }
  ],
  "post_auth_steps": [
    {
      "step_order": 1,
      "field_name": "api_domain",
      "label": "API Domain",
      "type": "auto",
      "required": true,
      "apply_to": "base_url",
      "options_source": {
        "method": "GET",
        "url": "https://api.pipedrive.com/v1/users/me",
        "headers": {
          "Authorization": "Bearer ${access_token}"
        },
        "items_path": null,
        "value_path": "data.company_domain",
        "label_path": "data.company_domain"
      }
    }
  ],
  "timeout": 30,
  "requests_per_second": {
    "max_requests": 80,
    "time_window_seconds": 2
  },
  "api_doc_url": "https://developers.pipedrive.com/docs/api/v1"
}